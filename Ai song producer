import google.generativeai as genai
import os

# --- ตั้งค่า API KEY ---
# จ๊ะโอ๋ต้องไปเอา API Key จาก Google AI Studio มาใส่นะครับ
API_KEY = "ใส่_API_KEY_ของจ๊ะโอ๋ตรงนี้" 
genai.configure(api_key=API_KEY)

def generate_thai_song():
    print("--- ยินดีต้อนรับสู่ JAAO Auto Gen (AI Songwriter) ---")
    print("เลือกแนวเพลงไทยตามกระแส:")
    print("1. T-Pop (สดใส/ไอดอล)\n2. ลูกทุ่งอินดี้ (กินใจ/อกหัก)\n3. Thai Indie Pop (ละมุน/ชิลล์)")
    
    choice = input("เลือกเบอร์ (1-3): ")
    topic = input("อยากแต่งเพลงเกี่ยวกับอะไร: ")

    genres = {"1": "T-Pop", "2": "ลูกทุ่งอินดี้", "3": "Thai Indie Pop"}
    selected_genre = genres.get(choice, "T-Pop")

    model = genai.GenerativeModel('gemini-1.5-flash')
    
    prompt = f"""
    ช่วยแต่งเนื้อเพลงแนว {selected_genre} เรื่อง "{topic}"
    เงื่อนไข:
    1. ใส่คอร์ดกีตาร์ประกอบ (เช่น [C] [Am]) ไว้เหนือเนื้อร้อง
    2. ใช้ชุดคอร์ดที่คนไทยชอบฟังและไพเราะ
    3. แบ่งท่อน Verse, Chorus ให้ชัดเจน
    """

    print("\n--- กำลังแต่งเพลงให้จ๊ะโอ๋... ---\n")
    response = model.generate_content(prompt)
    print(response.text)

if __name__ == "__main__":
    generate_thai_song()

